# Backend Environment Variables — GeoKost
# Salin file ini ke .env dan isi nilainya

# ─── App ──────────────────────────────────────
APP_ENV=development              # Ganti ke: production
APP_SECRET_KEY=GANTI-INI-DENGAN-STRING-ACAK-MINIMAL-32-KARAKTER
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── CORS ─────────────────────────────────────
# Development:
CORS_ORIGINS=["http://localhost:3000"]
# Production (ganti URL Vercel Anda):
# CORS_ORIGINS=["https://geokost.vercel.app","http://localhost:3000"]

# ─── Supabase / Database ──────────────────────
# Gunakan connection pooler (port 6543) untuk production
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Redis (Opsional) ─────────────────────────
# REDIS_URL=redis://default:PASSWORD@upstash-redis-host:6379

# ─── ML Model Paths ───────────────────────────
MODEL_C45_PATH=models_pkl/c45_model.pkl
MODEL_REGRESSION_PATH=models_pkl/price_regressor.pkl

# ─── Email / SMTP ──────────────────────────────
# Digunakan oleh: form kontak dan forgot-password
# Gmail: aktifkan "App Password" di https://myaccount.google.com/apppasswords
# Production (Render): masukkan nilai nyata di Environment Variables dashboard
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@geokost.id

# ─── Frontend URL ──────────────────────────────
# Development:
FRONTEND_URL=http://localhost:3000
# Production (ganti URL Vercel Anda):
# FRONTEND_URL=https://geokost.vercel.app
